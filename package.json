{
  "name": "hive",
  "version": "0.2.0",
  "description": "Discord multi-session Claude Code orchestrator",
  "type": "module",
  "scripts": {
    "hive": "bun run bin/hive",
    "gateway": "bun run bin/hive-gateway.ts",
    "mind": "bun run bin/hive-mind.ts",
    "validate": "bun run bin/hive validate",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "test": "bun test",
    "ci": "bun run typecheck && bun run lint && bun test"
  },
  "dependencies": {
    "@discordjs/rest": "^2.6.1",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "discord-api-types": "^0.37.120",
    "discord.js": "^14.25.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "bun-types": "latest"
  }
}
