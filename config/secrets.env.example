# Hive MCP Tool Secrets
# Copy this file to config/secrets.env and fill in your values.
# config/secrets.env is gitignored and will never be committed.
#
# Values here are interpolated into tool env vars via ${VAR_NAME} syntax.
# You can also export these as environment variables instead of using this file.

# GitHub Personal Access Token (for github tool)
# Required scopes: repo, read:org
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Brave Search API Key (for web-search tool)
# Get one at: https://brave.com/search/api/
# BRAVE_API_KEY=BSAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
